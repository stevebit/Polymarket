# Copy to .env and fill in. Never commit .env.

# CLOB (default is production)
POLYMARKET_HOST=https://clob.polymarket.com

# Polygon
POLYMARKET_CHAIN_ID=137

# Key that signs CLOB API requests (hex, with or without 0x).
# For email/Magic: export the key Polymarket gives you for API trading (see Polymarket docs / builder flow).
POLYMARKET_PRIVATE_KEY=

# 0 = EOA (MetaMask / hardware wallet)
# 1 = email / Magic (Polymarket "Sign in with email")
# 2 = browser wallet proxy
POLYMARKET_SIGNATURE_TYPE=1

# Required when POLYMARKET_SIGNATURE_TYPE is 1 or 2.
# This is the Polygon (0x…) address that actually holds your Polymarket USDC / positions —
# usually the same address shown in the Polymarket UI (profile, wallet, or deposit).
# It can differ from the address implied by the signing key alone.
POLYMARKET_FUNDER_ADDRESS=

# ---------------------------------------------------------------------------
# polymarket_weather research package
# ---------------------------------------------------------------------------
# Azure Postgres flexible server connection URL. Must include sslmode=require.
# Example: postgresql://weatheradmin:<urlencoded-pw>@<server>.postgres.database.azure.com:5432/weather?sslmode=require
WEATHER_POSTGRES_URL=

# NOAA Climate Data Online (CDO) v2 API token (free).
# Sign up at https://www.ncdc.noaa.gov/cdo-web/token
# Note the unusual variable casing — used as-is by the package.
NOAA_Token_ID=

# Comma-separated station slugs to ingest / model. Must exist in
# polymarket_weather/stations.py registry. If unset or blank, defaults to all
# 11 US Polymarket daily-temperature cities (see Agents.md).
# WEATHER_STATIONS=nyc,chicago

# User-Agent string for outbound HTTP calls (NWS API requires identification).
WEATHER_HTTP_UA=polymarket-weather (contact: you@example.com)


